generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum TipoDocumento {
  CC
  CE
  TI
  PAS
}

enum ZonaServicio {
  URBANA
  RURAL
}

enum EstadoCotizacion {
  EN_ESPERA
  CONVERTIDA
  ANULADA
}

enum EstadoReserva {
  PENDIENTE
  CONFIRMADA
  ANULADA
  FINALIZADO
  REPROGRAMADA
}

enum EstadoEnsayo {
  PENDIENTE
  LISTO
}

enum EstadoVenta {
  CONFIRMADO
  FINALIZADO
  VENTA_DIRECTA
  CANCELADA
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  NEQUI
  DAVIPLATA
  OTRO
}

enum TipoVenta {
  RESERVA
  DIRECTA
}

enum TipoEvento {
  BODA
  CUMPLEANOS
  QUINCEANIOS
  FUNERAL
  RECONCILIACION
  DIA_DE_MADRE
  AMOR
  ANIVERSARIO
  PADRES
  FIESTA
  OTRO
}

// ─── AUTENTICACIÓN ───────────────────────────────────────────────────────────

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String
  estado    Boolean  @default(true)
  rolId     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cliente  Cliente? 
  empleado Empleado?
  rol      Rol      @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@map("usuario")
}

// ─── EMPLEADO ────────────────────────────────────────────────────────────────

model Empleado {
  id                  Int           @id @default(autoincrement())
  usuarioId           Int           @unique
  tipoDocumento       TipoDocumento @default(CC)
  numeroDocumento     String        @unique
  fechaNacimiento     DateTime
  telefonoPrincipal   String
  telefonoAlternativo String?
  ciudad              String        @default("Medellín")
  barrio              String
  direccion           String
  zonaServicio        ZonaServicio  @default(URBANA)
  instrumentoPrincipal String
  otrosInstrumentos   String?
  anosExperiencia     Int           @default(0)
  foto                String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("empleado")
}

model Rol {
  id          Int          @id @default(autoincrement())
  nombre      String       @unique
  descripcion String?
  estado      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  usuarios    Usuario[]
  rolPermisos RolPermiso[]

  @@map("rol")
}

model RolPermiso {
  id        Int      @id @default(autoincrement())
  rolId     Int
  permisoId Int
  createdAt DateTime @default(now())

  rol     Rol     @relation(fields: [rolId],     references: [id], onDelete: Cascade)
  permiso Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@unique([rolId, permisoId])
  @@map("rol_permiso")
}

model Permiso {
  id          Int          @id @default(autoincrement())
  nombre      String       @unique
  estado      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  rolPermisos RolPermiso[]

  @@map("permiso")
}

// ─── CLIENTE ─────────────────────────────────────────────────────────────────

model Cliente {
  id                  Int           @id @default(autoincrement())
  usuarioId           Int           @unique
  email               String        @unique
  foto                String?
  apellido            String
  tipoDocumento       TipoDocumento @default(CC)
  numeroDocumento     String        @unique
  fechaNacimiento     DateTime
  telefonoPrincipal   String
  telefonoAlternativo String?
  ciudad              String        @default("Medellín")
  barrio              String
  direccion           String
  zonaServicio        ZonaServicio  @default(URBANA)
  activo              Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  usuario      Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  cotizaciones Cotizacion[]
  abonos       Abono[]
  ventas       Venta[]

  @@map("cliente")
}

// ─── SERVICIO ────────────────────────────────────────────────────────────────

model Servicio {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String
  precio      Decimal  @db.Decimal(10, 2)
  estado      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cotizacionServicios CotizacionServicio[]

  @@map("servicio")
}

// ─── CANCIÓN ─────────────────────────────────────────────────────────────────

model Repertorio {
  id         Int      @id @default(autoincrement())
  titulo     String
  artista    String
  genero     String
  categoria  String
  letra      String?
  audioUrl   String?
  duracion   String
  dificultad String
  portada    String?
  activa     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cotizaciones CotizacionRepertorio[]
  ensayos      EnsayoRepertorio[]

  @@map("repertorio")
}

// ─── COTIZACIÓN ──────────────────────────────────────────────────────────────

model Cotizacion {
  id                Int              @id @default(autoincrement())
  clienteId         Int?
  nombreHomenajeado String
  tipoEvento        TipoEvento
  fechaEvento       DateTime
  horaInicio        DateTime
  horaFin           DateTime
  direccionEvento   String
  notasAdicionales  String?
  totalEstimado     Decimal?         @db.Decimal(10, 2)
  esReservaDirecta  Boolean          @default(false)
  estado            EstadoCotizacion @default(EN_ESPERA)
  contactoNombre    String?
  contactoTelefono  String?
  contactoTelefono2 String?
  contactoEmail     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  cliente     Cliente?              @relation(fields: [clienteId], references: [id])
  servicios   CotizacionServicio[]
  repertorios CotizacionRepertorio[]
  reserva     Reserva?

  @@map("cotizacion")
}

model CotizacionServicio {
  id           Int @id @default(autoincrement())
  cotizacionId Int
  servicioId   Int
  cantidad     Int @default(1)

  cotizacion Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  servicio   Servicio   @relation(fields: [servicioId],   references: [id])

  @@unique([cotizacionId, servicioId])
  @@map("cotizacion_servicio")
}

model CotizacionRepertorio {
  id           Int @id @default(autoincrement())
  cotizacionId Int
  repertorioId Int
  orden        Int @default(0)

  cotizacion Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  repertorio Repertorio @relation(fields: [repertorioId], references: [id],onDelete: Cascade)

  @@unique([cotizacionId, repertorioId])
  @@map("cotizacion_repertorio")
}

// ─── RESERVA ─────────────────────────────────────────────────────────────────

model Reserva {
  id             Int           @id @default(autoincrement())
  cotizacionId   Int           @unique
  totalValor     Decimal       @db.Decimal(10, 2)
  saldoPendiente Decimal       @db.Decimal(10, 2)
  estado         EstadoReserva @default(PENDIENTE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  cotizacion Cotizacion @relation(fields: [cotizacionId], references: [id])
  abonos     Abono[]
  venta      Venta?

  @@map("reserva")
}

// ─── ABONO ───────────────────────────────────────────────────────────────────

model Abono {
  id         Int        @id @default(autoincrement())
  reservaId  Int
  clienteId  Int
  monto      Decimal    @db.Decimal(10, 2)
  fechaPago  DateTime
  metodoPago MetodoPago
  notas      String?
  nuevoSaldo Decimal    @db.Decimal(10, 2)
  createdAt  DateTime   @default(now())

  reserva Reserva @relation(fields: [reservaId], references: [id])
  cliente Cliente @relation(fields: [clienteId], references: [id])

  @@map("abono")
}

// ─── VENTA ───────────────────────────────────────────────────────────────────

model Venta {
  id          Int         @id @default(autoincrement())
  reservaId   Int?        @unique
  clienteId   Int
  tipo        TipoVenta
  estado      EstadoVenta
  montoTotal  Decimal     @db.Decimal(10, 2)
  montoPagado Decimal     @db.Decimal(10, 2)
  fechaVenta  DateTime
  metodoPago  MetodoPago
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  reserva Reserva? @relation(fields: [reservaId], references: [id])
  cliente Cliente  @relation(fields: [clienteId], references: [id])

  @@map("venta")
}

// ─── ENSAYO ──────────────────────────────────────────────────────────────────

model Ensayo {
  id        Int           @id @default(autoincrement())
  nombre    String
  fechaHora DateTime
  lugar     String
  ubicacion String?
  estado    EstadoEnsayo  @default(PENDIENTE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  repertorios EnsayoRepertorio[]

  @@map("ensayo")
}

model EnsayoRepertorio {
  id           Int @id @default(autoincrement())
  ensayoId     Int
  repertorioId Int

  ensayo     Ensayo     @relation(fields: [ensayoId],     references: [id], onDelete: Cascade)
  repertorio Repertorio @relation(fields: [repertorioId], references: [id], onDelete: Cascade)

  @@unique([ensayoId, repertorioId])
  @@map("ensayo_repertorio")
}

// ─── BLOQUEO MANUAL DE CALENDARIO ────────────────────────────────────────────

model BloqueoCalendario {
  id          Int      @id @default(autoincrement())
  fechaInicio DateTime
  fechaFin    DateTime
  motivo      String?
  createdAt   DateTime @default(now())

  @@map("bloqueo_calendario")
}

// ─── OTP RECUPERACIÓN CONTRASEÑA ─────────────────────────────────────────────

model PasswordResetOtp {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  expiresAt DateTime
  usado     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_otp")
}

model RegistroToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @default(uuid())
  email     String
  nombre    String
  telefono  String
  telefono2 String?
  usado     Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("registro_token")
}